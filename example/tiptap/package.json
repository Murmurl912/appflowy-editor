{
  "name": "tiptap-editor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.ts --bundle --minify --outfile=dist/tiptap-bundle.js --format=iife --global-name=TiptapEditor --target=es2020",
    "build:css": "cat node_modules/@tiptap/core/dist/style.css src/style.css > dist/tiptap.css",
    "build:all": "npm run build && npm run build:css"
  },
  "dependencies": {
    "@tiptap/core": "^2.11.0",
    "@tiptap/pm": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "@tiptap/extension-code-block-lowlight": "^2.11.0",
    "@tiptap/extension-table": "^2.11.0",
    "@tiptap/extension-table-row": "^2.11.0",
    "@tiptap/extension-table-cell": "^2.11.0",
    "@tiptap/extension-table-header": "^2.11.0",
    "@tiptap/extension-task-list": "^2.11.0",
    "@tiptap/extension-task-item": "^2.11.0",
    "@tiptap/extension-image": "^2.11.0",
    "@tiptap/extension-underline": "^2.11.0",
    "@tiptap/extension-highlight": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/extension-typography": "^2.11.0",
    "@tiptap/extension-text-align": "^2.11.0",
    "@tiptap/extension-horizontal-rule": "^2.11.0",
    "@tiptap/extension-link": "^2.11.0",
    "@tiptap/extension-subscript": "^2.11.0",
    "@tiptap/extension-superscript": "^2.11.0",
    "lowlight": "^3.2.0",
    "highlight.js": "^11.11.0",
    "turndown": "^7.2.0",
    "marked": "^15.0.0",
    "katex": "^0.16.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.0.0",
    "@types/turndown": "^5.0.0",
    "@types/katex": "^0.16.0"
  }
}
